#include <stdio.h>
#include <string.h>
#define MAX 100

// Stack structure
typedef struct {
    char data[MAX];
    int top;
} Stack;

// Initialize stack
void init(Stack *s) {
    s->top = -1;
}

// Push operation
void push(Stack *s, char c) {
    if (s->top == MAX - 1) {
        printf("Stack overflow\n");
        return;
    }
    s->data[++s->top] = c;
}

// Pop operation
char pop(Stack *s) {
    if (s->top == -1) {
        printf("Stack underflow\n");
        return;
    }
    return s->data[s->top--];
}

int main() {
    char str[MAX];
    Stack s;
    init(&s);
    printf("Enter a string: ");
    scanf("%s", str);

    // Push all characters into stack
    int len = strlen(str);
    for (int i = 0; i < len; i++) {
        push(&s, str[i]);
    }

    // Pop all characters to reverse string
    for (int i = 0; i < len; i++) {
        str[i] = pop(&s);
    }

    printf("The reversed string is: %s\n", str);
    return 0;
}
