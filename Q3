#include <stdio.h>
#define MAX 100

int stack[MAX];
int top = -1;

// Push index onto stack
void push(int x) {
    stack[++top] = x;
}

int pop() {
    return stack[top--];
}

int isEmpty() {
    return top == -1;
}

int main() {
    int arr[MAX], n;
    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter elements: ");
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int result[MAX]; // to store next greater elements

    // Traversing from right to left
    for (int i = n - 1; i >= 0; i--) {
        // To remove all smaller/equal elements from stack
        while (!isEmpty() && stack[top] <= arr[i]) {
            pop();
        }

        // If stack is empty -> no greater element
        if (isEmpty()) {
            result[i] = -1;
        } else {
            result[i] = stack[top];
        }

        push(arr[i]);
    }

    printf("Next Greater Elements:\n");
    for (int i = 0; i < n; i++) {
        printf("%d -> %d\n", arr[i], result[i]);
    }

    return 0;
}
